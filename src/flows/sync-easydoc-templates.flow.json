                "authentication": {
                  "type": "Raw",
                  "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                }
              }
            },
            "Apply_to_each_field": {
              "foreach": "@outputs('Get_template_detail')?['body/data_headers']",
              "actions": {
                "List_existing_field": {
                  "runAfter": {},
                  "metadata": {
                    "operationMetadataId": "a1f0c1e2-0009-4a10-9c01-000000000009"
                  },
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": {
                      "connectionName": "shared_commondataserviceforapps",
                      "operationId": "ListRecords",
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                    },
                    "parameters": {
                      "entityName": "alex_templatefieldmappings",
                      "$select": "alex_templatefieldmappingid",
                      "$filter": "@concat('_alex_templateid_value eq ', first(outputs('Resolve_template_id')?['body/value'])?['alex_signaturetemplateid'], ' and alex_externalfieldid eq ''', items('Apply_to_each_field')?['name'], '''')"
                    },
                    "authentication": {
                      "type": "Raw",
                      "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                    }
