                        "item/alex_isactive": "@equals(items('Apply_to_each_template')?['status'], 'active')",
                        "item/alex_templatesummary": "@items('Apply_to_each_template')?['description']",
                        "item/alex_lastsyncedon": "@utcNow()"
                      },
                      "authentication": {
                        "type": "Raw",
                        "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                      }
                    }
                  }
                }
              },
              "expression": {
                "greater": [
                  "@length(outputs('List_existing_template')?['body/value'])",
                  0
                ]
              },
              "type": "If"
            },
            "Resolve_template_id": {
