<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="EasyDo" constructor="TemplateFieldMapping" version="0.1.2" display-name-key="TemplateFieldMapping_Display" description-key="TemplateFieldMapping_Desc" control-type="standard" >
    <external-service-usage enabled="false">
    </external-service-usage>
    <!-- Anchor: bound to the alex_pcfhost column on the template form. The control
         does not really use this value; it reads the open record id from the page
         context and drives everything through context.webAPI. -->
    <property name="hostField" display-name-key="HostField_Display" description-key="HostField_Desc" of-type="SingleLine.Text" usage="bound" required="false" />
    <!-- Language override: auto (follow user UI), en, or he. -->
    <property name="language" display-name-key="Language_Display" description-key="Language_Desc" of-type="Enum" usage="input" required="false" default-value="auto">
      <value name="auto" display-name-key="Language_Auto">auto</value>
      <value name="en" display-name-key="Language_En">en</value>
      <value name="he" display-name-key="Language_He">he</value>
    </property>
    <resources>
      <code path="index.ts" order="1"/>
      <css path="css/TemplateFieldMapping.css" order="1" />
    </resources>
    <feature-usage>
      <uses-feature name="WebAPI" required="true" />
      <uses-feature name="Utility" required="true" />
    </feature-usage>
  </control>
</manifest>
